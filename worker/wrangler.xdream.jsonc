{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "agentparty-xdream",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-01",
  "workers_dev": true,
  "vars": {
    "AUTH_PROVIDERS": "[{\"id\":\"lark\",\"kind\":\"lark\",\"label\":\"Sign in with Lark\",\"client_id\":\"cli_aac5bdcb23389e17\"}]",
    "HOSTED_MEMBERSHIP_GATING": "true"
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "CHANNELS",
        "class_name": "ChannelDO"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["ChannelDO"]
    }
  ],
  "assets": {
    "directory": "../web/dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*", "/openapi.json"]
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "agentparty-xdream",
      "database_id": "3b508259-41d5-4cff-8def-319b12935203",
      "migrations_dir": "migrations"
    }
  ],
  // 频道附件（#176）：图片/文件走 R2。部署前运营需先建桶（xdream 账号）：
  //   wrangler r2 bucket create agentparty-attachments-xdream
  "r2_buckets": [
    {
      "binding": "ATTACHMENTS",
      "bucket_name": "agentparty-attachments-xdream"
    }
  ],
  "routes": [
    {
      "pattern": "agentparty.pwtk-dev.work",
      "custom_domain": true
    }
  ],
  // #137 可观测性：开启 Cloudflare Workers Logs（内建，无需外部服务 / 密钥）。
  // 线上出安全事件或故障时可在 dashboard 查 console.error（如审计落库失败标记）与请求日志。
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  }
}
